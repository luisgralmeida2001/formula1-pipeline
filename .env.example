# ==============================
# GCP
# ==============================
GCP_PROJECT_ID=seu-projeto-gcp
GCP_BUCKET_NAME=f1-pipeline-bronze
GCP_REGION=us-east1

# Caminho para o arquivo de credenciais GCP (service account)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp_credentials.json

# ==============================
# Databricks
# ==============================
DATABRICKS_HOST=https://seu-workspace.azuredatabricks.net
DATABRICKS_TOKEN=seu-token-aqui

# ==============================
# Ingestão
# ==============================
# Ano da temporada a ser coletada
F1_SEASON=2025

# OpenF1 API base URL (não precisa de chave)
OPENF1_BASE_URL=https://api.openf1.org/v1
